---

---

<section id="contact" class="relative py-32 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Section header -->
    <div class="flex items-center justify-center gap-4 mb-8">
      <span class="font-mono text-neon-blue dark:text-neon-cyan text-sm">04.</span>

      <h2 class="text-3xl md:text-4xl font-bold text-light-800 dark:text-white">Get In Touch</h2>
    </div>

    <div class="neon-line w-24 mx-auto mb-12"></div>

    <!-- Terminal-style message -->
    <div class="bg-light-100 dark:bg-dark-700/50 border-glow rounded-xl overflow-hidden box-glow max-w-xl mx-auto mb-12">
      <div class="flex items-center gap-2 px-4 py-3 bg-light-200 dark:bg-dark-800/80 border-b border-light-300 dark:border-neon-cyan/10">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
        </div>
        <span class="font-mono text-xs text-light-400 dark:text-gray-500 ml-2">harsh@dev:~/contact</span>
      </div>
      <div class="p-6 font-mono text-sm text-left space-y-3">
        <div>
          <span class="text-neon-blue dark:text-neon-cyan">$</span>
          <span class="text-light-500 dark:text-gray-400"> echo $CONTACT_MESSAGE</span>
        </div>
        <p class="text-light-600 dark:text-gray-300 pl-2 border-l-2 border-neon-blue/20 dark:border-neon-cyan/20">
          I'm always open to new opportunities, collaborations, and interesting conversations.
          Whether you have a project in mind or just want to say hello — my inbox is open.
        </p>
        <div>
          <span class="text-neon-blue dark:text-neon-cyan">$</span>
          <span class="text-green-600 dark:text-green-400 animate-glow-pulse"> █</span>
        </div>
      </div>
    </div>

    <!-- Contact button -->
    <a
      href="mailto:hello@harshkhatore.com"
      class="group relative inline-flex items-center gap-3 px-10 py-4 font-mono text-sm overflow-hidden rounded-xl"
    >
      <div class="absolute inset-0 bg-neon-blue/10 dark:bg-neon-cyan/10 border border-neon-blue/30 dark:border-neon-cyan/30 rounded-xl group-hover:bg-neon-blue/20 dark:group-hover:bg-neon-cyan/20 group-hover:border-neon-blue/60 dark:group-hover:border-neon-cyan/60 transition-all duration-300 dark:group-hover:shadow-[0_0_30px_rgba(0,240,255,0.2)]"></div>
      <svg class="relative w-5 h-5 text-neon-blue dark:text-neon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
      </svg>
      <span class="relative text-neon-blue dark:text-neon-cyan group-hover:text-light-800 dark:group-hover:text-white transition-colors">Say Hello</span>
    </a>

    <!-- Social links -->
    <div class="mt-12 flex items-center justify-center gap-6">
      <!-- GitHub -->
      <a href="https://github.com/harshkhatore" target="_blank" rel="noopener noreferrer"
        class="text-light-400 dark:text-gray-600 hover:text-neon-blue dark:hover:text-neon-cyan transition-colors duration-300 group" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
      </a>
      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/harshkhatore" target="_blank" rel="noopener noreferrer"
        class="text-light-400 dark:text-gray-600 hover:text-neon-blue dark:hover:text-neon-cyan transition-colors duration-300 group" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
      </a>
      <!-- Twitter/X -->
      <a href="https://twitter.com/harshkhatore" target="_blank" rel="noopener noreferrer"
        class="text-light-400 dark:text-gray-600 hover:text-neon-blue dark:hover:text-neon-cyan transition-colors duration-300 group" aria-label="Twitter">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
