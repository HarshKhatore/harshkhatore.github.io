---

<section class="px-4 md:px-6 pt-6 pb-2 max-w-7xl mx-auto">
  <div class="card rounded-lg overflow-hidden">
    <div class="card-header">
      <span class="indicator"></span>
      <span>System Identity</span>
      <span class="ml-auto text-dark-600">PID 001</span>
    </div>
    <div class="card-body">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-dark-500 mb-2">// operator</p>
          <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight leading-none">
            Harsh <span class="text-phosphor glow-green">Khatore</span>
          </h1>
          <p class="mt-3 text-sm text-dark-500">
            <span class="text-amber">$</span> role <span class="text-dark-600">=</span> <span class="text-phosphor/80">"Software Engineer"</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-3 text-[10px] uppercase tracking-widest text-dark-500">
          <div class="flex items-center gap-1.5 px-3 py-1.5 bg-dark-800 border border-dark-700 rounded">
            <span class="w-1.5 h-1.5 rounded-full bg-phosphor/60"></span>
            Available
          </div>
          <div class="flex items-center gap-1.5 px-3 py-1.5 bg-dark-800 border border-dark-700 rounded">
            <span class="w-1.5 h-1.5 rounded-full bg-amber/60"></span>
            India
          </div>
          <div class="flex items-center gap-1.5 px-3 py-1.5 bg-dark-800 border border-dark-700 rounded">
            <span class="text-dark-600">&#9650;</span>
            <span id="uptime-counter" class="tabular-nums">00:00:00</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Session uptime counter
  const start = Date.now();
  function updateUptime() {
    const elapsed = Math.floor((Date.now() - start) / 1000);
    const h = String(Math.floor(elapsed / 3600)).padStart(2, '0');
    const m = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
    const s = String(elapsed % 60).padStart(2, '0');
    const el = document.getElementById('uptime-counter');
    if (el) el.textContent = `${h}:${m}:${s}`;
  }
  updateUptime();
  setInterval(updateUptime, 1000);
</script>
