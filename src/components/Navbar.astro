---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#beyond', label: 'Beyond Code' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="font-mono text-lg font-bold group">
      <span class="text-neon-blue dark:text-neon-cyan group-hover:text-glow transition-all">&lt;</span>
      <span class="text-light-800 dark:text-white">HK</span>
      <span class="text-neon-blue dark:text-neon-cyan group-hover:text-glow transition-all">/&gt;</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-mono text-sm text-light-500 dark:text-gray-400 hover:text-neon-blue dark:hover:text-neon-cyan transition-colors duration-300 relative group"
        >
          <span class="text-neon-purple opacity-0 group-hover:opacity-100 transition-opacity">{'>'}_</span>
          {link.label}
        </a>
      ))}

      <!-- Theme toggle -->
      <button id="theme-toggle" class="relative w-10 h-10 flex items-center justify-center rounded-lg border border-light-200 dark:border-neon-cyan/20 bg-light-100 dark:bg-dark-700/50 hover:bg-light-200 dark:hover:bg-dark-600 transition-all duration-300 group" aria-label="Toggle theme">
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-5 h-5 text-neon-cyan hidden dark:block transition-transform duration-300 group-hover:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-5 h-5 text-neon-blue dark:hidden transition-transform duration-300 group-hover:-rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile hamburger -->
    <div class="md:hidden flex items-center gap-3">
      <!-- Mobile theme toggle -->
      <button id="theme-toggle-mobile" class="relative w-9 h-9 flex items-center justify-center rounded-lg border border-light-200 dark:border-neon-cyan/20 bg-light-100 dark:bg-dark-700/50 transition-all duration-300" aria-label="Toggle theme">
        <svg class="w-4 h-4 text-neon-cyan hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
        <svg class="w-4 h-4 text-neon-blue dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
      </button>
      <button id="mobile-toggle" class="flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
        <span class="w-6 h-0.5 bg-neon-blue dark:bg-neon-cyan transition-all duration-300" id="bar1"></span>
        <span class="w-6 h-0.5 bg-neon-blue dark:bg-neon-cyan transition-all duration-300" id="bar2"></span>
        <span class="w-4 h-0.5 bg-neon-blue dark:bg-neon-cyan transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white/95 dark:bg-dark-900/95 backdrop-blur-xl border-t border-light-200 dark:border-neon-cyan/10">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-mono text-sm text-light-500 dark:text-gray-400 hover:text-neon-blue dark:hover:text-neon-cyan transition-colors py-2"
        >
          <span class="text-neon-purple mr-2">$</span>{link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Theme toggle
  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    if (isDark) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateNavbarScroll();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  function updateNavbarScroll() {
    const isDark = document.documentElement.classList.contains('dark');
    if (window.scrollY > 50) {
      if (isDark) {
        navbar?.classList.add('bg-dark-900/80', 'backdrop-blur-xl', 'border-b', 'border-neon-cyan/10');
        navbar?.classList.remove('bg-white/80', 'border-light-200');
      } else {
        navbar?.classList.add('bg-white/80', 'backdrop-blur-xl', 'border-b', 'border-light-200');
        navbar?.classList.remove('bg-dark-900/80', 'border-neon-cyan/10');
      }
    } else {
      navbar?.classList.remove('bg-dark-900/80', 'bg-white/80', 'backdrop-blur-xl', 'border-b', 'border-neon-cyan/10', 'border-light-200');
    }
  }
  window.addEventListener('scroll', updateNavbarScroll);
  updateNavbarScroll();

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
