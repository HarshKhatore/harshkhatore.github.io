---
const navLinks = [
  { href: '#about', label: 'ABT' },
  { href: '#experience', label: 'EXP' },
  { href: '#beyond', label: 'EXT' },
  { href: '#contact', label: 'COM' },
];
---

<nav class="sticky top-0 z-30 bg-dark-950 border-b border-dark-700">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-10">
      <!-- Left: Identity -->
      <div class="flex items-center gap-4">
        <a href="#" class="flex items-center gap-2 text-phosphor text-xs font-bold tracking-wider glow-green">
          <span class="text-[10px]">&#9654;</span> HK_SYS
        </a>
        <span class="text-dark-600">|</span>
        <span class="hidden sm:inline text-[10px] text-dark-500 uppercase tracking-widest">Mission Control v1.0</span>
      </div>

      <!-- Center: Nav links (desktop) -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-1 text-[10px] uppercase tracking-widest text-dark-500 hover:text-phosphor hover:bg-phosphor/5 transition-all duration-200"
          >
            [{link.label}]
          </a>
        ))}
      </div>

      <!-- Right: Status indicators -->
      <div class="flex items-center gap-3 text-[10px] uppercase tracking-wider">
        <div class="hidden sm:flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-phosphor animate-pulse-slow shadow-[0_0_4px_rgba(0,255,65,0.5)]"></span>
          <span class="text-dark-500">Online</span>
        </div>
        <span class="text-dark-600 hidden sm:inline">|</span>
        <span class="text-dark-500" id="status-clock">--:--:--</span>

        <!-- Mobile toggle -->
        <button id="mobile-toggle" class="md:hidden text-dark-500 hover:text-phosphor ml-2 transition-colors" aria-label="Toggle menu">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-dark-700 bg-dark-950">
    <div class="px-4 py-3 flex flex-col">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="py-2 text-[11px] uppercase tracking-widest text-dark-500 hover:text-phosphor transition-colors"
        >
          <span class="text-phosphor/40 mr-2">$</span>{link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Live clock
  function updateClock() {
    const now = new Date();
    const time = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const el = document.getElementById('status-clock');
    if (el) el.textContent = time;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
