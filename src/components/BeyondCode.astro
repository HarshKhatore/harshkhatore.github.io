---
const items = [
  {
    title: 'Item Title',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
    icon: 'rocket',
    color: 'cyan',
  },
  {
    title: 'Another Item',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
    icon: 'bulb',
    color: 'purple',
  },
  {
    title: 'One More Thing',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
    icon: 'star',
    color: 'pink',
  },
];

const iconMap: Record<string, string> = {
  rocket: 'M13 10V3L4 14h7v7l9-11h-7z',
  bulb: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  star: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
};

const colorMap: Record<string, { border: string; hoverBorder: string; bg: string; text: string; hoverText: string; tagBg: string; tagBorder: string }> = {
  cyan: {
    border: 'border-neon-cyan/15',
    hoverBorder: 'hover:border-neon-cyan/40',
    bg: 'bg-neon-cyan/10',
    text: 'text-neon-cyan',
    hoverText: 'group-hover:text-neon-cyan',
    tagBg: 'bg-neon-cyan/10',
    tagBorder: 'border-neon-cyan/20',
  },
  purple: {
    border: 'border-neon-purple/15',
    hoverBorder: 'hover:border-neon-purple/40',
    bg: 'bg-neon-purple/10',
    text: 'text-neon-purple',
    hoverText: 'group-hover:text-neon-purple',
    tagBg: 'bg-neon-purple/10',
    tagBorder: 'border-neon-purple/20',
  },
  pink: {
    border: 'border-neon-pink/15',
    hoverBorder: 'hover:border-neon-pink/40',
    bg: 'bg-neon-pink/10',
    text: 'text-neon-pink',
    hoverText: 'group-hover:text-neon-pink',
    tagBg: 'bg-neon-pink/10',
    tagBorder: 'border-neon-pink/20',
  },
};
---

<section id="beyond" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <span class="font-mono text-neon-cyan text-sm">03.</span>
      <h2 class="text-3xl md:text-4xl font-bold">Beyond Code</h2>
      <div class="neon-line flex-1 max-w-xs"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {items.map((item) => {
        const c = colorMap[item.color];
        return (
          <div class={`bg-dark-700/30 border ${c.border} rounded-xl p-6 ${c.hoverBorder} transition-all duration-300 group`}>
            <div class={`w-10 h-10 rounded-lg ${c.bg} flex items-center justify-center mb-4`}>
              <svg class={`w-5 h-5 ${c.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[item.icon]}></path>
              </svg>
            </div>
            <h3 class={`text-lg font-bold text-white mb-2 ${c.hoverText} transition-colors`}>{item.title}</h3>
            <p class="text-gray-400 text-sm mb-4">{item.description}</p>
            <div class="flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class={`px-2 py-1 text-xs font-mono rounded ${c.tagBg} border ${c.tagBorder} ${c.text}`}>
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Flexible note -->
    <div class="mt-8 bg-dark-700/20 border-glow rounded-xl p-6">
      <div class="font-mono text-sm">
        <span class="text-neon-purple">// </span>
        <span class="text-gray-500">This section is a work in progress. More coming soon...</span>
      </div>
    </div>
  </div>
</section>
