---
const items = [
  {
    title: 'Item Title',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
  },
  {
    title: 'Another Item',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
  },
  {
    title: 'One More Thing',
    description: 'A brief description of this interest, hobby, or side project.',
    tags: ['Tag1', 'Tag2'],
  },
];
---

<div id="beyond" class="card rounded-lg overflow-hidden h-full">
  <div class="card-header">
    <span class="w-1.5 h-1.5 rounded-full bg-danger shadow-[0_0_4px_rgba(255,51,51,0.5)]"></span>
    <span>Beyond Code</span>
    <span class="ml-auto text-dark-600">PID 005</span>
  </div>
  <div class="card-body space-y-3">
    {items.map((item, index) => (
      <div class="p-3 bg-dark-800 rounded border border-dark-700 hover:border-phosphor/15 transition-colors group">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[10px] text-dark-600 tabular-nums">{String(index + 1).padStart(2, '0')}</span>
          <h3 class="text-xs font-bold text-white group-hover:text-phosphor transition-colors">{item.title}</h3>
        </div>
        <p class="text-[11px] text-dark-500 leading-relaxed pl-6">{item.description}</p>
        <div class="flex flex-wrap gap-1.5 mt-2 pl-6">
          {item.tags.map((tag) => (
            <span class="px-1.5 py-0.5 text-[9px] uppercase tracking-wider bg-dark-900 border border-dark-700 text-dark-500 rounded">
              {tag}
            </span>
          ))}
        </div>
      </div>
    ))}

    <!-- Placeholder note -->
    <div class="text-[10px] text-dark-600 pt-1">
      <span class="text-phosphor/30">//</span> More entries loading...
    </div>
  </div>
</div>
