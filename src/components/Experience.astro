---
const experiences = [
  {
    company: 'Company Name',
    position: 'Job Title',
    duration: 'Month Year - Present',
    description: 'Brief description of your role and key achievements',
    technologies: ['Tech1', 'Tech2', 'Tech3'],
    active: true,
  },
  {
    company: 'Previous Company',
    position: 'Previous Position',
    duration: 'Month Year - Month Year',
    description: 'Brief description of your role and key achievements',
    technologies: ['Tech1', 'Tech2'],
    active: false,
  },
];
---

<div id="experience" class="card rounded-lg overflow-hidden h-full">
  <div class="card-header">
    <span class="indicator"></span>
    <span>Experience Log</span>
    <span class="ml-auto text-dark-600">PID 003</span>
  </div>
  <div class="card-body space-y-4">
    {experiences.map((exp, index) => (
      <div class="relative pl-4 border-l border-dark-700">
        <!-- Timeline dot -->
        <div class={`absolute -left-[3.5px] top-1 w-[7px] h-[7px] rounded-full ${exp.active ? 'bg-phosphor shadow-[0_0_6px_rgba(0,255,65,0.5)]' : 'bg-dark-500 border border-dark-600'}`}></div>

        <div class="mb-1 flex items-start justify-between gap-2">
          <div>
            <h3 class="text-sm font-bold text-white leading-tight">{exp.position}</h3>
            <p class={`text-xs ${exp.active ? 'text-phosphor/70' : 'text-amber/70'}`}>{exp.company}</p>
          </div>
          <span class="text-[10px] text-dark-500 uppercase tracking-wider whitespace-nowrap shrink-0">{exp.duration}</span>
        </div>

        <p class="text-[11px] text-dark-500 mt-1 leading-relaxed">{exp.description}</p>

        <div class="flex flex-wrap gap-1.5 mt-2">
          {exp.technologies.map((tech) => (
            <span class="px-1.5 py-0.5 text-[9px] uppercase tracking-wider bg-dark-800 border border-dark-700 text-dark-500 rounded">
              {tech}
            </span>
          ))}
        </div>

        {index < experiences.length - 1 && <div class="h-3"></div>}
      </div>
    ))}
  </div>
</div>
