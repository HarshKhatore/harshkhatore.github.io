---
const experiences = [
  {
    company: 'Company Name',
    position: 'Job Title',
    duration: 'Month Year - Present',
    description: 'Brief description of your role and key achievements',
    technologies: ['Tech1', 'Tech2', 'Tech3'],
  },
  {
    company: 'Previous Company',
    position: 'Previous Position',
    duration: 'Month Year - Month Year',
    description: 'Brief description of your role and key achievements',
    technologies: ['Tech1', 'Tech2'],
  },
];

const patents = [
  {
    title: 'Patent Title',
    number: 'Patent Number / Application No.',
    status: 'Granted',
    date: 'Year',
    description: 'Brief description of the patent and the problem it solves.',
  },
  {
    title: 'Another Patent Title',
    number: 'Patent Number / Application No.',
    status: 'Pending',
    date: 'Year',
    description: 'Brief description of the patent and the problem it solves.',
  },
];
---

<section id="experience" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <span class="font-mono text-neon-cyan text-sm">02.</span>
      <h2 class="text-3xl md:text-4xl font-bold">Experience</h2>
      <div class="neon-line flex-1 max-w-xs"></div>
    </div>

    <div class="space-y-8">
      {experiences.map((exp, index) => (
        <div class="group">
          <div class="flex flex-col md:flex-row md:items-start gap-6">
            <!-- Timeline dot and line -->
            <div class="flex flex-col items-center">
              <div class="w-4 h-4 rounded-full bg-neon-cyan border-2 border-neon-cyan/30 group-hover:border-neon-cyan transition-all duration-300"></div>
              {index < experiences.length - 1 && (
                <div class="w-0.5 h-24 bg-gradient-to-b from-neon-cyan/30 to-transparent mt-2"></div>
              )}
            </div>

            <!-- Experience card -->
            <div class="flex-1 bg-dark-700/30 border border-neon-cyan/10 rounded-xl p-6 hover:box-glow transition-all duration-300">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-3">
                <div>
                  <h3 class="text-xl font-bold text-white">{exp.position}</h3>
                  <p class="text-neon-cyan font-mono text-sm">{exp.company}</p>
                </div>
                <span class="font-mono text-sm text-gray-400 whitespace-nowrap">{exp.duration}</span>
              </div>
              
              <p class="text-gray-300 mb-4">{exp.description}</p>
              
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map((tech) => (
                  <span class="px-2 py-1 text-xs font-mono rounded bg-neon-cyan/10 border border-neon-cyan/20 text-neon-cyan">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Patents subsection -->
    <div class="mt-20">
      <div class="flex items-center gap-3 mb-10">
        <svg class="w-6 h-6 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <h3 class="text-2xl font-bold text-white">Patents</h3>
        <div class="h-px flex-1 max-w-xs bg-gradient-to-r from-neon-purple/40 to-transparent"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {patents.map((patent) => (
          <div class="bg-dark-700/30 border border-neon-purple/15 rounded-xl p-6 hover:border-neon-purple/40 transition-all duration-300 group">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h4 class="text-lg font-bold text-white group-hover:text-neon-purple transition-colors">{patent.title}</h4>
              <span class={`shrink-0 font-mono text-xs px-3 py-1 rounded-full ${patent.status === 'Granted' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20'}`}>
                {patent.status}
              </span>
            </div>
            <p class="font-mono text-xs text-neon-purple/70 mb-3">{patent.number} &middot; {patent.date}</p>
            <p class="text-gray-400 text-sm">{patent.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
