---
const currentYear = new Date().getFullYear();
---

<footer class="px-4 md:px-6 pb-6 pt-2 max-w-7xl mx-auto">
  <div class="border-t border-dark-700 pt-4">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-[10px] uppercase tracking-widest text-dark-600">
      <span>System.initialized <span class="text-phosphor/30">//</span> Harsh Khatore</span>
      <span>Astro + Tailwind <span class="text-dark-700">|</span> &copy; {currentYear}</span>
    </div>
  </div>
</footer>
