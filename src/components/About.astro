---

---

<section id="about" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <span class="font-mono text-neon-blue dark:text-neon-cyan text-sm">01.</span>
      <h2 class="text-3xl md:text-4xl font-bold text-light-800 dark:text-white">About Me</h2>
      <div class="neon-line flex-1 max-w-xs"></div>
    </div>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Text content -->
      <div class="md:col-span-3 space-y-6">
        <!-- Terminal window -->
        <div class="bg-light-100 dark:bg-dark-700/50 border-glow rounded-xl overflow-hidden box-glow">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 px-4 py-3 bg-light-200 dark:bg-dark-800/80 border-b border-light-300 dark:border-neon-cyan/10">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <span class="font-mono text-xs text-light-400 dark:text-gray-500 ml-2">harsh@dev:~/about</span>
          </div>
          <!-- Terminal content -->
          <div class="p-6 font-mono text-sm leading-relaxed space-y-4">
            <div>
              <span class="text-neon-blue dark:text-neon-cyan">$</span>
              <span class="text-light-500 dark:text-gray-400"> cat about.md</span>
            </div>
            <div class="text-light-600 dark:text-gray-300 space-y-4 pl-2 border-l-2 border-neon-blue/20 dark:border-neon-cyan/20">
              <p>
                I'm a <span class="text-neon-blue dark:text-neon-cyan">Software Engineer</span> passionate about building robust,
                scalable, and elegant software systems. I love turning complex problems into simple,
                beautiful solutions.
              </p>
              <p>
                With a strong foundation in modern development practices, I work across the
                <span class="text-neon-purple">full stack</span> — from crafting pixel-perfect
                interfaces to designing efficient backend architectures.
              </p>
              <p>
                I'm constantly exploring new technologies and pushing the boundaries of what's
                possible with code. When I'm not coding, you'll find me diving into system design,
                open source, or experimenting with the latest tech.
              </p>
            </div>
            <div>
              <span class="text-neon-blue dark:text-neon-cyan">$</span>
              <span class="text-green-600 dark:text-green-400 animate-glow-pulse"> █</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Info cards -->
      <div class="md:col-span-2 space-y-4">
        <div class="bg-light-100 dark:bg-dark-700/30 border-glow rounded-xl p-6 hover:box-glow transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-neon-blue/10 dark:bg-neon-cyan/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-neon-blue dark:text-neon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="font-mono text-sm text-neon-blue dark:text-neon-cyan">Languages</h3>
          </div>
          <p class="text-light-500 dark:text-gray-400 text-sm">TypeScript, Python, JavaScript, Java, C++, Go</p>
        </div>

        <div class="bg-light-100 dark:bg-dark-700/30 border-glow rounded-xl p-6 hover:box-glow transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-neon-purple/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
              </svg>
            </div>
            <h3 class="font-mono text-sm text-neon-purple">Focus</h3>
          </div>
          <p class="text-light-500 dark:text-gray-400 text-sm">Full-Stack Development, System Design, Cloud Architecture</p>
        </div>

        <div class="bg-light-100 dark:bg-dark-700/30 border-glow rounded-xl p-6 hover:box-glow transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-neon-pink/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="font-mono text-sm text-neon-pink">Learning</h3>
          </div>
          <p class="text-light-500 dark:text-gray-400 text-sm">Always exploring new frameworks, tools, and paradigms</p>
        </div>
      </div>
    </div>
  </div>
</section>
