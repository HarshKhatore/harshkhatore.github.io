---
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/inter';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Harsh Khatore — Software Engineer. Building the future, one line at a time.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Harsh Khatore" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-dark-950 text-gray-300 font-mono antialiased overflow-x-hidden animate-flicker">
    <!-- CRT scanline overlay -->
    <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.04]">
      <div class="absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_1px,rgba(0,255,65,0.08)_1px,rgba(0,255,65,0.08)_2px)]"></div>
    </div>

    <!-- Moving scanline beam -->
    <div class="pointer-events-none fixed inset-0 z-50">
      <div class="absolute w-full h-[2px] bg-gradient-to-r from-transparent via-phosphor/10 to-transparent animate-scanline"></div>
    </div>

    <!-- Noise grain overlay -->
    <div class="pointer-events-none fixed inset-0 z-40 opacity-[0.015] mix-blend-overlay"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 128px 128px;">
    </div>

    <slot />

    <!-- Global styles -->
    <style is:global>
      ::selection {
        background: rgba(0, 255, 65, 0.25);
        color: #fff;
      }

      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: #050505;
      }
      ::-webkit-scrollbar-thumb {
        background: #00ff4133;
        border-radius: 2px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #00ff4166;
      }

      html {
        scrollbar-color: #00ff4133 #050505;
        scrollbar-width: thin;
      }

      .glow-green {
        text-shadow: 0 0 8px rgba(0, 255, 65, 0.6), 0 0 25px rgba(0, 255, 65, 0.2);
      }

      .glow-amber {
        text-shadow: 0 0 8px rgba(255, 176, 0, 0.6), 0 0 25px rgba(255, 176, 0, 0.2);
      }

      .card {
        background: #0a0a0a;
        border: 1px solid #1a1a1a;
        transition: border-color 0.3s ease;
      }

      .card:hover {
        border-color: #00ff4120;
      }

      .card-header {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #1a1a1a;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #555;
      }

      .card-header .indicator {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #00ff41;
        box-shadow: 0 0 6px rgba(0, 255, 65, 0.5);
      }

      .card-body {
        padding: 1.25rem;
      }
    </style>
  </body>
</html>
